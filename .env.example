OPENAI_API_KEY=
JOB_AGENT_MODEL=gpt-5
JOB_AGENT_OUTPUT_DIR=./output
JOB_AGENT_DATA_DIR=./data
PLAYWRIGHT_HEADLESS=false
JOB_AGENT_MODEL_TIMEOUT_MS=120000
PLAYWRIGHT_STORAGE_STATE_PATH=./data/generated/playwright-state.json

# Local model via Ollama (OpenAI-compatible API)
# Set JOB_AGENT_LOCAL_MODEL to the Ollama model name, e.g. deepseek-r1
# Set JOB_AGENT_USE_LOCAL to a comma-separated list of agents to run locally:
#   fit, answers, tailor, cover — or "all" to use local for everything
# Agents NOT in the list will always use OpenAI.
# Default (if unset): tailor and cover use OpenAI; fit and answers use local if LOCAL_MODEL is set.
JOB_AGENT_LOCAL_MODEL=deepseek-r1
JOB_AGENT_USE_LOCAL=fit,answers
JOB_AGENT_OLLAMA_BASE_URL=http://localhost:11434/v1

# LinkedIn scout
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
